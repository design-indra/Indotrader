# ════════════════════════════════════════════
#   IndoTrader v3.0 — Environment Variables
# ════════════════════════════════════════════

# Indodax API Credentials (WAJIB untuk Live Mode)
INDODAX_API_KEY=your_api_key_here
INDODAX_SECRET_KEY=your_secret_key_here

# Auth Login (ganti default ini!)
AUTH_EMAIL=admin@indotrader.app
AUTH_PASSWORD=indotrader123

# Demo Mode Balance Awal (IDR)
DEMO_BALANCE=100000

# Bot Risk Settings
MAX_POSITIONS=1
MAX_RISK_PERCENT=40
STOP_LOSS_PERCENT=1.0
TAKE_PROFIT_PERCENT=2.5
TRAILING_STOP_PERCENT=0.5
MAX_CONSECUTIVE_LOSSES=3

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
