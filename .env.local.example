# Indodax API Credentials (ISI DENGAN API KEY KAMU)
INDODAX_API_KEY=your_api_key_here
INDODAX_SECRET_KEY=your_secret_key_here

# App URL - ganti dengan URL Vercel kamu setelah deploy
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

NODE_ENV=production

# Demo Mode Default Balance (IDR) - modal awal demo
DEMO_BALANCE=10000000

# Bot Settings
BOT_INTERVAL_MS=5000
MAX_POSITIONS=2
MAX_RISK_PERCENT=15
STOP_LOSS_PERCENT=1
TAKE_PROFIT_PERCENT=2
TRAILING_STOP_PERCENT=0.5
MAX_CONSECUTIVE_LOSSES=3

# Trading Pairs
TRADING_PAIRS=btc_idr,eth_idr,bnb_idr,sol_idr
